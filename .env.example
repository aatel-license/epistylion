# ─── LLM Backend ────────────────────────────────────────────────────────────
# URL del server OpenAI-compatible (llama-cpp-python, Ollama, LM Studio, ecc.)
LLM_BASE_URL=http://localhost:1234/v1

# API key (lascia "none" per server locali senza auth)
LLM_API_KEY=none

# Modello da usare (come appare nel server)
LLM_MODEL=qwen2.5-coder-7b-instruct

# Temperatura di generazione (0.0 – 1.0)
LLM_TEMPERATURE=0.2

# Max token nella risposta
LLM_MAX_TOKENS=4096

# ─── MCP Config ─────────────────────────────────────────────────────────────
# Percorso al file JSON di configurazione dei server MCP
MCP_CONFIG_PATH=./mcp_servers.json

# Timeout (secondi) per inizializzare ogni server MCP
MCP_INIT_TIMEOUT=30

# ─── Variabili passate ai processi MCP (se necessario) ───────────────────────
# Esempio: token per server MCP che lo richiedono via env
# BLENDER_MCP_TOKEN=xxx
# SCRAPLING_API_KEY=yyy


# ─── OpenAI Proxy Server (server_openai.py) ─────────────────────────────────
# API key richiesta dai client (lascia vuota per nessuna autenticazione)
EPISTYLION_API_KEY=

# Formato log: json (per Loki/ELK/Datadog) oppure text (per sviluppo)
EPISTYLION_LOG_FORMAT=json

# Livello log: DEBUG / INFO / WARNING / ERROR
EPISTYLION_LOG_LEVEL=INFO

# Origini CORS separate da virgola (* = tutte)
EPISTYLION_CORS_ORIGINS=*

# Rate limit: richieste/minuto per IP (0 = disabilitato)
EPISTYLION_RATE_LIMIT=0
